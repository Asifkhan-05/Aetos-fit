{
  "name": "aetos-fit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/electron.cjs",
  "build": {
    "appId": "com.aetos.fit",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "server/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "node server/index.js",
    "build": "tsc -b && vite build",
    "electron:build": "npm run build && electron-builder -w",
    "capacitor:init": "npx cap init aetos-fit com.aetos.fit --web-dir dist",
    "capacitor:android": "npx cap add android && npx cap sync android",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "8.4.0",
    "cors": "^2.8.6",
    "electron-is-dev": "3.0.1",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/cli": "8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}